# Base URL of your own github-readme-stats deployment (no trailing slash).
# The shared public instance gets rate-limited and returns 503, so fork it
# and deploy to Vercel (it is a serverless function — it CANNOT run on
# GitHub Pages): https://github.com/anuraghazra/github-readme-stats#deploy-on-your-own
#
# Local dev:  copy this file to .env.local and set the value below.
# Production: this site builds on GitHub Pages via .github/workflows/deploy.yml,
#             so also add a repository variable named GH_STATS_BASE
#             (Settings -> Secrets and variables -> Actions -> Variables).
NEXT_PUBLIC_GH_STATS_BASE=https://your-stats.vercel.app
